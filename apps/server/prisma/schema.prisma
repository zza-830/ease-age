generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id          String   @id @default(cuid())
  phoneNumber String   @unique
  password    String
  fullName    String
  role        String   // elderly | family | staff | admin
  avatarUrl   String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  elderlyProfile        ElderlyProfile?
  familyRelations       FamilyRelation[]
  conversationsAsMember ConversationMember[]
  sentMessages          Message[]         @relation("SentMessages")
  callerCalls           VideoCallRecord[] @relation("CallerCalls")
  calleeCalls           VideoCallRecord[] @relation("CalleeCalls")
  serviceOrders         ServiceOrder[]
  familyMemories        FamilyMemory[]    @relation("FamilyMemories")
}

// ─── Elderly Profile ─────────────────────────────────────────────────────────

model ElderlyProfile {
  id                    String    @id @default(cuid())
  userId                String    @unique
  fullName              String
  gender                String?   // male | female
  birthDate             DateTime?
  identityCardNumber    String?
  residentialAddress    String?
  emergencyContactPhone String?
  medicalHistoryJson    String?   // JSON string
  allergyDescription    String?
  bloodType             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  familyRelations FamilyRelation[]
  healthRecords   HealthRecord[]
  medications     Medication[]
  medicalCheckups MedicalCheckup[]
  serviceOrders   ServiceOrder[]
  familyMemories  FamilyMemory[]
}

// ─── Family Relation ─────────────────────────────────────────────────────────

model FamilyRelation {
  id               String   @id @default(cuid())
  userId           String
  elderlyProfileId String
  relationshipType String
  isPrimaryContact Boolean  @default(false)
  permissionsJson  String   @default("{}") // JSON string
  createdAt        DateTime @default(now())

  // Relations
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  elderlyProfile ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, elderlyProfileId])
}

// ─── Health Record ───────────────────────────────────────────────────────────

model HealthRecord {
  id                     String   @id @default(cuid())
  elderlyProfileId       String
  recordType             String
  measurementValueJson   String   // JSON string
  measurementUnit        String
  measuredAt             DateTime
  sourceDeviceIdentifier String?
  notes                  String?
  createdAt              DateTime @default(now())

  // Relations
  elderlyProfile ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId, recordType])
  @@index([measuredAt])
}

// ─── Medication ──────────────────────────────────────────────────────────────

model Medication {
  id                   String   @id @default(cuid())
  elderlyProfileId     String
  medicationName       String
  dosageDescription    String
  frequencyDescription String
  startDate            DateTime?
  endDate              DateTime?
  reminderScheduleJson String   @default("[]") // JSON array string
  isActive             Boolean  @default(true)
  createdAt            DateTime @default(now())

  // Relations
  elderlyProfile ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId])
}

// ─── Medical Checkup ─────────────────────────────────────────────────────────

model MedicalCheckup {
  id               String   @id @default(cuid())
  elderlyProfileId String
  hospitalName     String
  checkupDate      DateTime
  reportFileUrl    String?
  summaryText      String?
  resultsJson      String?  // JSON string
  createdAt        DateTime @default(now())

  // Relations
  elderlyProfile ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)

  @@index([elderlyProfileId])
}

// ─── Service Category ────────────────────────────────────────────────────────

model ServiceCategory {
  id              String  @id @default(cuid())
  categoryName    String  @unique
  iconIdentifier  String
  descriptionText String?
  displayOrder    Int     @default(0)
  isActive        Boolean @default(true)

  // Relations
  services Service[]
}

// ─── Service ─────────────────────────────────────────────────────────────────

model Service {
  id              String  @id @default(cuid())
  categoryId      String
  serviceName     String
  descriptionText String
  basePrice       Float
  priceUnit       String
  imageUrlsJson   String  @default("[]") // JSON array string
  isActive        Boolean @default(true)
  createdAt       DateTime @default(now())

  // Relations
  category      ServiceCategory @relation(fields: [categoryId], references: [id])
  serviceOrders ServiceOrder[]

  @@index([categoryId])
}

// ─── Service Order ───────────────────────────────────────────────────────────

model ServiceOrder {
  id                   String   @id @default(cuid())
  orderNumber          String   @unique
  userId               String
  elderlyProfileId     String
  serviceId            String
  orderStatus          String   @default("pending")
  totalAmount          Float
  scheduledServiceTime DateTime
  serviceAddress       String
  specialInstructions  String?
  customerRating       Int?
  reviewText           String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  // Relations
  user           User           @relation(fields: [userId], references: [id])
  elderlyProfile ElderlyProfile @relation(fields: [elderlyProfileId], references: [id])
  service        Service        @relation(fields: [serviceId], references: [id])

  @@index([userId])
  @@index([elderlyProfileId])
  @@index([orderStatus])
}

// ─── Knowledge Category ──────────────────────────────────────────────────────

model KnowledgeCategory {
  id               String  @id @default(cuid())
  categoryName     String  @unique
  parentCategoryId String?
  iconIdentifier   String
  displayOrder     Int     @default(0)

  // Self-relation for nested categories
  parent   KnowledgeCategory?  @relation("CategoryTree", fields: [parentCategoryId], references: [id])
  children KnowledgeCategory[] @relation("CategoryTree")

  // Relations
  articles KnowledgeArticle[]
}

// ─── Knowledge Article ───────────────────────────────────────────────────────

model KnowledgeArticle {
  id              String    @id @default(cuid())
  categoryId      String
  title           String
  contentMarkdown String
  summaryText     String?
  coverImageUrl   String?
  authorName      String?
  tagsJson        String    @default("[]") // JSON array string
  viewCount       Int       @default(0)
  isPublished     Boolean   @default(false)
  publishedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Relations
  category KnowledgeCategory @relation(fields: [categoryId], references: [id])

  @@index([categoryId])
  @@index([isPublished])
}

// ─── Family Memory ───────────────────────────────────────────────────────────

model FamilyMemory {
  id               String   @id @default(cuid())
  elderlyProfileId String
  familyUserId     String
  memoryType       String   // photo | video | text | voice
  contentText      String?
  fileUrl          String?
  descriptionText  String?
  createdAt        DateTime @default(now())

  // Relations
  elderlyProfile ElderlyProfile @relation(fields: [elderlyProfileId], references: [id], onDelete: Cascade)
  familyUser     User           @relation("FamilyMemories", fields: [familyUserId], references: [id])

  @@index([elderlyProfileId])
}

// ─── Conversation ────────────────────────────────────────────────────────────

model Conversation {
  id               String   @id @default(cuid())
  conversationType String   // private | group
  conversationName String?
  createdAt        DateTime @default(now())

  // Relations
  members  ConversationMember[]
  messages Message[]
}

// ─── Conversation Member ─────────────────────────────────────────────────────

model ConversationMember {
  id             String   @id @default(cuid())
  conversationId String
  userId         String
  joinedAt       DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
}

// ─── Message ─────────────────────────────────────────────────────────────────

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  messageType    String   // text | image | video | voice | system
  contentText    String?
  fileUrl        String?
  isRead         Boolean  @default(false)
  createdAt      DateTime @default(now())

  // Relations
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation("SentMessages", fields: [senderId], references: [id])

  @@index([conversationId])
  @@index([senderId])
}

// ─── Video Call Record ───────────────────────────────────────────────────────

model VideoCallRecord {
  id              String    @id @default(cuid())
  callerUserId    String
  calleeUserId    String
  callStatus      String    // ringing | connected | ended | missed
  startedAt       DateTime?
  endedAt         DateTime?
  durationSeconds Int?

  // Relations
  caller User @relation("CallerCalls", fields: [callerUserId], references: [id])
  callee User @relation("CalleeCalls", fields: [calleeUserId], references: [id])

  @@index([callerUserId])
  @@index([calleeUserId])
}
